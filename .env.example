# Supabase — find these in your project's API settings (Project Settings → API Keys)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# "Publishable key" in the dashboard (formerly the "anon" key), starts with sb_publishable_
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key

# Server-only. The "secret key" (formerly "service_role"), starts with sb_secret_.
# Used for privileged operations (never exposed to the browser).
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-key

# 32-byte key (base64) for AES-256-GCM credential encryption (added in a later step).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CREDENTIAL_ENCRYPTION_KEY=replace-me

# --- Notifications (expiry reminders) ---
# Resend API key (free tier). Get one at https://resend.com. If left unset,
# emails are skipped and logged — the cron still runs without errors.
RESEND_API_KEY=re_your-key
# Sender address. Use onboarding@resend.dev for testing, or an address on a
# domain you've verified in Resend to email clients.
EMAIL_FROM=onboarding@resend.dev
# Secret protecting the cron endpoint. Vercel sends this as a Bearer token.
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CRON_SECRET=replace-me
